# =============================================================================
# 1) Ver só a interface SEM PostgreSQL (modo demonstração)
# =============================================================================
# Ative e rode: npm run dev
# Login: master@vendacomciencia.com / maisvendas!@2026 (não consulta o banco)
DEMO_MODE=1

# Pode ser um placeholder enquanto DEMO_MODE=1 (o app não usa o banco no login demo).
# Para uso real, use a URL correta do seu Postgres.
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/venda_comciencia?schema=public"
# Obrigatório no schema Prisma: em localhost pode ser igual ao DATABASE_URL.
DIRECT_URL="postgresql://postgres:SUA_SENHA@localhost:5432/venda_comciencia?schema=public"

# NextAuth — gere um segredo longo (ex.: openssl rand -base64 32)
AUTH_SECRET="gere-uma-string-aleatoria-longa"

# Em dev: porta do next dev (geralmente 3000)
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# 2) Uso real no PC — PostgreSQL + seed (desligue DEMO_MODE ou remova)
# =============================================================================
# DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/venda_comciencia?schema=public"
# Depois: npx prisma db push   (ou migrate deploy)   e   npm run db:seed

# =============================================================================
# 3) SUPABASE — Project Settings → Database (obrigatório em produção/Vercel)
# =============================================================================
# Runtime (pooler modo TRANSAÇÃO — não use 5432 "Session" no serverless: esgota ~15 ligações)
# DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
#
# Migrations / prisma migrate (conexão direta ao Postgres, host db.[REF].supabase.co)
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres"

# =============================================================================
# 4) VERCEL (deploy) — Project → Settings → Environment Variables
# =============================================================================
# DATABASE_URL     = Transaction pooler :6543 + ?pgbouncer=true&connection_limit=1
# DIRECT_URL       = conexão "Direct" (db.xxx.supabase.co:5432) — usada em migrate deploy
# AUTH_SECRET      = o mesmo ou um novo segredo forte
# NEXTAUTH_URL     = https://SEU-PROJETO.vercel.app   (URL pública, sem barra no final)
# NÃO use DEMO_MODE=1 em produção.
